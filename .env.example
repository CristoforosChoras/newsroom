# n8n "SEO Report API" webhook — used server-side only by src/app/api/agents/seo/route.ts.
# These values NEVER reach the browser. Copy to .env.local and fill in the secret.
N8N_SEO_WEBHOOK_URL=https://onlygroup.app.n8n.cloud/webhook/matrix-seo-report
N8N_SEO_RETRO_WEBHOOK_URL=https://onlygroup.app.n8n.cloud/webhook/matrix-seo-retro
N8N_TRENDS_WEBHOOK_URL=https://onlygroup.app.n8n.cloud/webhook/matrix-trends
N8N_SEO_SECRET=replace-with-the-shared-secret

# Social Radar service (standalone) — proxied by src/app/api/agents/ideas/route.ts.
# Feeds BOTH the Trends and Content-Gap pages (one engine). Uses N8N_SEO_SECRET as
# its shared secret (x-matrix-secret). Server-side only.
SOCIAL_RADAR_URL=http://localhost:8080

# n8n "AMNA Inbox API" webhook — proxied by src/app/api/agents/inbox/route.ts.
# Returns ingested ΑΠΕ-ΜΠΕ wire articles as ready Story Cells (the "Λήψη ΑΠΕ-ΜΠΕ"
# button pulls them). Uses N8N_SEO_SECRET as the shared secret. Server-side only.
N8N_AMNA_INBOX_WEBHOOK_URL=https://paotalk.app.n8n.cloud/webhook/matrix-amna-inbox

# n8n "KPI API" webhook — proxied by src/app/api/agents/kpi/route.ts. Returns
# {siteKpi, network} from the KPI agent (GA4 pageviews + WP REST article counts).
N8N_KPI_WEBHOOK_URL=https://paotalk.app.n8n.cloud/webhook/matrix-kpi
